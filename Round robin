#include <stdio.h>

typedef struct process
{
    int at, bt, ct, wt, tat, pid, rt;
} p;

int main()
{
    int n, qt;
    printf("\nEnter the number of processes: ");
    scanf("%d", &n);

    printf("Enter the quantum time: ");
    scanf("%d", &qt);

    p s[n];
    int queue[100], front = 0, rear = 0;
    int visited[n];

    for (int i = 0; i < n; i++)
    {
        s[i].pid = i + 1;
        printf("\nEnter arrival time and burst time: ");
        scanf("%d %d", &s[i].at, &s[i].bt);
        s[i].rt = s[i].bt;
        visited[i] = 0;
    }

    int current_time = 0, completed = 0;

    queue[rear++] = 0;
    visited[0] = 1;

    while (completed < n)
    {
        int idx = queue[front++];

        if (s[idx].rt > qt)
        {
            current_time += qt;
            s[idx].rt -= qt;
        }
        else
        {
            current_time += s[idx].rt;
            s[idx].rt = 0;
            s[idx].ct = current_time;
            s[idx].tat = s[idx].ct - s[idx].at;
            s[idx].wt = s[idx].tat - s[idx].bt;
            completed++;
        }
        for (int i = 0; i < n; i++)
        {
            if (s[i].at <= current_time && !visited[i])
            {
                queue[rear++] = i;
                visited[i] = 1;
            }
        }


        if (s[idx].rt > 0)
        {
            queue[rear++] = idx;
        }

        if (front == rear)
        {
            for (int i = 0; i < n; i++)
            {
                if (!visited[i])
                {
                    queue[rear++] = i;
                    visited[i] = 1;
                    current_time = s[i].at;
                    break;
                }
            }
        }
    }

    printf("\nPID\tAT\tBT\tCT\tTAT\tWT\n");
    for (int i = 0; i < n; i++)
    {
        printf("P%d\t%d\t%d\t%d\t%d\t%d\n",
               s[i].pid, s[i].at, s[i].bt,
               s[i].ct, s[i].tat, s[i].wt);
    }

    return 0;
}
